# Rastro — Environment Configuration
# Copy to .env and adjust values.
#
# Required:
#   (none — everything has safe defaults)
#
# Optional:

# Authentication secret (auto-generated if not set)
RASTRO_AUTH_SECRET=

# Ollama AI backend (optional — rule-based fallback if unavailable)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# OpenAI API (optional — used when Ollama is unavailable)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Database (auto-configured in desktop mode; override for dev)
# DATABASE_URL=sqlite:///./database/rastro.db

# Scan scheduler interval in minutes (default: 30)
RASTRO_SCAN_INTERVAL=30
